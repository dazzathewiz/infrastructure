# reverse_sync.env — host-specific config for reverse_sync.sh
#
# Copy this file to /boot/config/reverse_sync.env on the Unraid host
# and fill in your values. The script sources it automatically if present.
# This file is NOT committed — it lives on the boot device only.

# ---- Required --------------------------------------------------------

# Source host (TrueNAS IP or DNS name). No default — script fails fast.
RS_SRC_HOST="192.0.2.10"

# ---- Optional (defaults shown) ---------------------------------------

# Source SSH user. Default: admin
# RS_SRC_USER="admin"

# Local interface to bind SSH source to (e.g. for forcing 10G path).
# Leave unset / empty to let the OS choose.
# RS_SRC_BIND="192.0.2.1"

# TrueNAS root path containing the media share dirs.
# Default: /mnt/nas/plex_data
# RS_SRC_ROOT="/mnt/nas/plex_data"

# Unraid destination root. Should be the FUSE union (/mnt/user) so rsync
# sees content across all storage tiers, not just one pool.
# Default: /mnt/user
# RS_DST_ROOT="/mnt/user"

# SSH key Unraid uses to authenticate to the source.
# Default: /root/.ssh/reverse_sync_key
# RS_SSH_KEY="/root/.ssh/reverse_sync_key"

# known_hosts location. Must be on a real filesystem (not the boot device,
# which doesn't support hardlinks for ssh's atomic rotation).
# Default: /mnt/user/appdata/reverse_sync/known_hosts
# RS_KNOWN_HOSTS="/mnt/user/appdata/reverse_sync/known_hosts"

# Where run logs are written.
# Default: /mnt/user/appdata/reverse_sync
# RS_LOG_DIR="/mnt/user/appdata/reverse_sync"

# Backup root for in-place overwrites. Must exist as an Unraid share
# before running --apply. Each apply creates a new <TS> subdir under this.
# Default: /mnt/user/reverse_sync_backups
# RS_BACKUP_ROOT="/mnt/user/reverse_sync_backups"

# Comma-separated list of share names to sync. Spaces in share names OK
# (the parser uses comma as the delimiter). Default reflects a typical
# Plex layout.
# Default: TV Shows,Movies,DVD Rips
# RS_SHARES="TV Shows,Movies,DVD Rips"
